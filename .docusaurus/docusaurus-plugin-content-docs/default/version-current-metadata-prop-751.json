      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/intro": {
      "id": "Devdocs/Shopify/themes/intro",
      "title": "Overview",
      "description": "Các theme của Shopify cơ bản được xây dựng dựa trên templating language là Liquid, đi kèm với nó là HTML, CSS, JavaScript và JSON. Shopify cung cấp một số các công cụ và best practices để tối ưu quá trình phát triển.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Basic/Intro": {
      "id": "Devdocs/Shopify/themes/Liquid/Basic/Intro",
      "title": "Liquid - Introduction",
      "description": "Liquid sử dụng sự kết hợp giữa objects, tags và filters trong các template files để hiển thị dữ liệu.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Basic/Operators": {
      "id": "Devdocs/Shopify/themes/Liquid/Basic/Operators",
      "title": "Operators",
      "description": "Là một templating language, Liquid giới hạn khá nhiều các toán tử, hầu như chỉ là các toán tử logic hoặc các phép so sánh, câu điều kiện đơn giản.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Basic/Truthy-and-Falsy": {
      "id": "Devdocs/Shopify/themes/Liquid/Basic/Truthy-and-Falsy",
      "title": "Truthy and falsy",
      "description": "Khi một giá trị không thuộc kiểu dữ liệu boolean được sử dụng trong một ngữ cảnh có điều kiện (như các tag điều kiện {% if ... %}), Liquid sẽ quyết định quy đổi giá trị đó về true hoặc false. Giá trị được quy đổi về true được gọi là truthy. Giá trị được quy đổi về false được gọi là falsy.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Basic/Types": {
      "id": "Devdocs/Shopify/themes/Liquid/Basic/Types",
      "title": "Types",
      "description": "Liquid objects có 6 kiểu dữ liệu:",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Basic/Whitespace-Control": {
      "id": "Devdocs/Shopify/themes/Liquid/Basic/Whitespace-Control",
      "title": "Whitespace control",
      "description": "Trong Liquid, bạn có thể thêm kí tự - vào các tag mở đóng như {{- và -}} hoặc {%- và -%} để loại bỏ khoảng trống của giá trị hoặc biểu thức mà Liquid tạo ra.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Filters": {
      "id": "Devdocs/Shopify/themes/Liquid/Filters",
      "title": "Filters",
      "description": "Tham khảo document chính thức dưới đây:",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/index": {
      "id": "Devdocs/Shopify/themes/Liquid/index",
      "title": "Liquid",
      "description": "Liquid là một templating language được thiết kế bởi Shopify. Ngôn ngữ này được sử dụng nhiều bởi các công ty và trong các dự án phần mềm hiện nay.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/themes/Liquid/Liquid-Cheat-Sheet": {
