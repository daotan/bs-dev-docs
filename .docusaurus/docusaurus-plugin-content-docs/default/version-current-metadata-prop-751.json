    },
    "Devdocs/Shopify/apps/intro": {
      "id": "Devdocs/Shopify/apps/intro",
      "title": "Overview",
      "description": "Trước khi bắt đầu quá trình phát triển app của bạn, bạn nên trước hết hiểu được Shopify apps làm những gì và chúng có thể hoạt động với Shopify bằng cách nào.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/apps/polaris": {
      "id": "Devdocs/Shopify/apps/polaris",
      "title": "Polaris",
      "description": "Hệ thống thiết kế Polaris bao gồm các nguyên tắc, design patterns của các UI components, tokens, icons để xây dựng apps trong Shopify admin.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/apps/Shopify App Remix/api-access-scope": {
      "id": "Devdocs/Shopify/apps/Shopify App Remix/api-access-scope",
      "title": "Access Scopes",
      "description": "Khi làm việc với Shopify Admin Graphql query hoặc mutation, sẽ có một số query yêu cầu quyền truy cập (access scope) của app để có thể sử dụng. Để thiết lập access scope cho app của bạn, bạn cần update access_scope nằm trong file config của app.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/apps/Shopify App Remix/api-extension": {
      "id": "Devdocs/Shopify/apps/Shopify App Remix/api-extension",
      "title": "Extensions",
      "description": "Một app extension cho phép bạn thêm chức năng của ứng dụng vào giao diện người dùng Shopify.",
      "sidebar": "devDocsSidebar"
    },
    "Devdocs/Shopify/apps/Shopify App Remix/architecture": {
